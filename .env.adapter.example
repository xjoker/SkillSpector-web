# SkillSpector adapter deployment env.
# Copy this file to `.env` next to docker-compose.yml and fill secrets there.

# Recommended for browser access and required before binding the service to non-localhost
# unless SKILLSPECTOR_AUTH_TOKEN is configured instead.
SKILLSPECTOR_API_USERNAME=
SKILLSPECTOR_API_PASSWORD=

# Bearer token for API clients and MCP token fallback. Optional when Basic auth is set.
# Use a long random value; do not commit the real token.
SKILLSPECTOR_AUTH_TOKEN=

# Web/API upload limit in MiB.
SKILLSPECTOR_WEB_MAX_UPLOAD_MB=50

# Public base URL used in returned upload ticket URLs when behind a reverse proxy.
# Use https://... for any non-localhost deployment.
SKILLSPECTOR_PUBLIC_URL=

# Used by docker-compose.lan.yml. Set explicitly before LAN exposure.
# SKILLSPECTOR_LAN_BIND_IP=10.0.4.43

# Static scans do not require an LLM key. Set provider credentials only when enabling use_llm=true.
SKILLSPECTOR_PROVIDER=nv_build
NVIDIA_INFERENCE_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_PROXY_ENDPOINT_URL=
ANTHROPIC_PROXY_API_KEY=

# Remote MCP mode only. The default docker-compose.yml runs Web/API mode on port 8477.
# If you run `skillspector upload-mcp`, expose both the MCP control port and this upload data port.
SKILLSPECTOR_MCP_AUTH_TOKEN=
SKILLSPECTOR_MCP_PUBLIC_URL=
SKILLSPECTOR_MCP_UPLOAD_HOST=127.0.0.1
SKILLSPECTOR_MCP_UPLOAD_PORT=0
SKILLSPECTOR_MCP_UPLOAD_PUBLIC_URL=
